{
  "$schema": "./node_modules/oxlint/configuration_schema.json",
  "plugins": ["unicorn", "oxc"],
  "categories": {
    "correctness": "error"
  },
  "rules": {
    "no-undef": "error"
  },
  "ignorePatterns": ["node_modules/**"],
  "env": {
    "builtin": true,
    "node": true,
    "es2024": true
  }
}
