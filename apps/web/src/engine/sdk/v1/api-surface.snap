};

// timing.ts
const createUiTiming: (values: UiTimingValues) => UiTiming;
type MusicFade = {
  fadeIn: number;
  fadeOut: number;
};
type MusicFadeKind = uiTiming.MusicFadeKind;
type UiTiming = {
  cssVars: UiCssVars;
  musicChapterCrossfadeSecs: () => number;
  musicDeathFadeOutSecs: () => number;
  narrativeSequenceMs: (textBlockCount: number) => number;
  notificationsSequenceMs: (notificationCount: number) => number;
  resolutionLeadMs: () => number;
  resolutionSequenceMs: (notificationCount: number, rollCount: number) => number;
  resolveMusicFade: (kind: MusicFadeKind | undefined, hadTrack: boolean) => MusicFade;
  rollsSequenceMs: (rollCount: number) => number;
  values: UiTimingValues;
};
type UiTimingValues = {
  backgroundFadeMs: number;
  chapterTransitionMs: number;
  choiceFadeMs: number;
  choiceInitialDelayMs: number;
  choiceResolvingSweepMs: number;
  choiceStaggerMs: number;
  damageCriticalPulseMs: number;
  damageHitMs: number;
  locationFadeMs: number;
  musicCrossfadeSecs: number;
  musicLoopDelayMs: number;
  narrativeBufferMs: number;
  narrativeFadeMs: number;
  narrativeInitialDelayMs: number;
  narrativeMaxDelayMs: number;
  narrativeStaggerMs: number;
  notificationBufferMs: number;
  notificationFadeMs: number;
  notificationScanDelayMs: number;
  notificationScanMs: number;
  notificationStaggerMs: number;
  resolutionEntryFadeMs: number;
  responseHeaderFadeMs: number;
  rollDurationMs: number;
  rollPipIntervalMs: number;
  rollSequenceBufferMs: number;
  rollSettleMs: number;
  rollStaggerMs: number;
  rollVerdictFadeMs: number;
  stageDirectionFadeMs: number;
};

// types.ts
type CatalogEntry = {
  description?: string | undefined;
  internal: boolean;
  title?: string | undefined;
};
type CharacterView = {
  color?: string | undefined;
  metrics: RelationshipMetricView[];
  name: string;
  portrait?: TextureCue | undefined;
  ref_id: string;
  subtitle?: string | undefined;
  voiceRef?: string | undefined;
};
type CheckPreview = {
  attemptsUsed?: number | undefined;
  difficulty: number;
  label?: string | undefined;
  maxAttempts?: number | undefined;
  rollMode?: RollMode | undefined;
  sides?: number | undefined;
  stat: string;
};
type ChoiceAction = Wire.ChoiceAction;
type ChoiceView = {
  action?: ChoiceAction | undefined;
  check?: CheckPreview | undefined;
  disabledReason?: string | undefined;
  enabled: boolean;
  id: string;
  label: string;
  sfx?: SfxCue | undefined;
};
type CommandResult = {
  chapter_changed?: boolean | undefined;
  error?: EngineError | undefined;
  examine?: ItemExamineView | undefined;
  ok: boolean;
  rolls?: RollRecord[] | undefined;
  selected_sfx?: SfxCue | undefined;
  triggered_sfx?: SfxCue | undefined;
  view?: GameView | undefined;
};
type DialogueSide = Wire.DialogueSide;
type EngineError = Wire.EngineError;
type GameView = {
  background?: TextureCue | undefined;
  chapter_id?: string | undefined;
  chapter_title?: string | undefined;
  characters: CharacterView[];
  choices: ChoiceView[];
  events: string[];
  flags: Record<string, unknown>;
  inventory: Record<string, number>;
  inventory_items: InventoryItemView[];
  item_actions: ItemActionView[];
  meta: MetaCatalog;
  mode: NodeMode;
  music?: MusicCue | undefined;
  node_id: string;
  player_stats: Record<string, number>;
  relationships: RelationshipCharacterView[];
  scenario_title?: string | undefined;
  text: TextBlock[];
  title?: string | undefined;
};
type InventoryItemView = {
  count: number;
  icon?: TextureCue | undefined;
  name: string;
  ref_id: string;
};
type ItemActionView = {
  action_id: string;
  disabledReason?: string | undefined;
  enabled: boolean;
  item_ref: string;
  label: string;
};
type ItemExamineView = {
  description: string;
  examine_text: string;
  icon?: TextureCue | undefined;
  name: string;
  ref_id: string;
};
type MetaCatalog = {
  events: Record<string, CatalogEntry>;
  flags: Record<string, CatalogEntry>;
};
type MusicCue = {
  loop: boolean;
  ref_id: string;
  src: string;
};
type NodeMode = Wire.NodeMode;
type RelationshipCharacterView = {
  color?: string | undefined;
  metrics: RelationshipMetricView[];
  name: string;
  ref_id: string;
  subtitle?: string | undefined;
};
type RelationshipMetricView = {
  key: string;
  value: number;
};
type RollMode = Wire.RollMode;
type RollRecord = Wire.RollRecord;
type ScenarioBundle = {
  assets: Uint8Array<ArrayBufferLike>;
  characters: Uint8Array<ArrayBufferLike>;
  items: Uint8Array<ArrayBufferLike>;
  project?: { chapters: Array<{ id: string; title: string; }>; startChapterId: string; } | undefined;
  scenario: Uint8Array<ArrayBufferLike>;
};
type SfxCue = {
  ref_id: string;
  src: string;
};
type TextBlock = {
  emotion?: string | undefined;
  kind: string;
  side?: DialogueSide | undefined;
  speaker?: string | undefined;
  text: string;
};
type TextureCue = {
  ref_id: string;
  src: string;
};
type UiNotification = Wire.UiNotification;

// ui/components.ts
type ChoicesProps = {
  borderColor: string;
  choiceClass: string;
  isEnding: boolean;
  isGameOver: boolean;
  isRolling: boolean;
  isTerminal: boolean;
  onChoose: (choiceId: string) => void;
  onContinue: () => void;
  onOpenLoad: () => void;
  onOpenMainMenu: () => void;
  onRestart: () => void;
  onReturnToChapterStart: () => void;
  view: GameView;
  visible: boolean;
};
type GameScreenProps = {
  commandPending: boolean;
  examine: ItemExamineView | null;
  lastRolls: RollRecord[];
  lastSavedAt?: string | null | undefined;
  notifications: UiNotification[];
  onChoose: (choiceId: string) => void;
  onContinue: () => void;
  onCreateSupportBundle?: (() => void) | undefined;
  onExamine: (itemRef: string) => void;
  onOpenLoad: () => void;
  onOpenMainMenu: () => void;
  onRestart: () => void;
  onReturnToChapterStart: () => void;
  onSave: () => void;
  onUseItem: (itemRef: string, actionId: string) => void;
  presentationBaselineStats: Record<string, number>;
  presentationLocation?: string | undefined;
  resolutionEpoch: number;
  view: GameView;
};
type IntelProps = {
  initialIntelRef?: string | undefined;
  memories: string[];
  meta: MetaCatalog;
};
type InventoryProps = {
  commandPending: boolean;
  examine: ItemExamineView | null;
  initialItemRef?: string | undefined;
  onExamine: (itemRef: string) => void;
  onUse: (itemRef: string, actionId: string) => void;
  view: GameView;
};
type JournalProps = {
  events: string[];
  meta: MetaCatalog;
};
type MainMenuProps = {
  initialSlot?: number | undefined;
  menuLoading: boolean;
  onContinueSlot: (index: number) => void;
  onCreateSupportBundle?: (() => void) | undefined;
  onRestartSlot: (index: number) => void;
};
type NarrativeProps = {
  block: TextBlock;
  characters: CharacterLookup;
  first?: boolean | undefined;
  isGameOver: boolean;
  onCharacterProfile?: ((character: CharacterView) => void) | undefined;
  prevBlock?: TextBlock | undefined;
};
type ResolutionProps = {
  notifications: UiNotification[];
  onNotificationActivate?: ((notification: UiNotification) => void) | undefined;
  rolls: RollRecord[];
};
type SystemMenuProps = {
  isTerminal: boolean;
  lastSavedAt?: string | null | undefined;
  onCreateSupportBundle?: (() => void) | undefined;
  onOpenLoad?: (() => void) | undefined;
  onOpenMainMenu: () => void;
  onRestart: () => void;
  onSave: () => void;
};
type TextGameComponentOverrides = Partial<Slots.TextGameComponents>;
type TextGameComponents = {
  Choices: ComponentType<ChoicesProps>;
  GameScreen: ComponentType<GameScreenProps>;
  Intel: ComponentType<IntelProps>;
  Inventory: ComponentType<InventoryProps>;
  Journal: ComponentType<JournalProps>;
  MainMenu: ComponentType<MainMenuProps>;
  Narrative: ComponentType<NarrativeProps>;
  Resolution: ComponentType<ResolutionProps>;
  SystemMenu: ComponentType<SystemMenuProps>;
  Vitals: ComponentType<VitalsProps>;
};
const useTextGameComponents: () => TextGameComponents;
type VitalsProps = {
  borderColor: string;
  controls?: ReactNode;
  damagePulse?: DamagePulse | null | undefined;
  onDamagePulseEnd?: (() => void) | undefined;
  playerStats: Record<string, number>;
};

