// audio.ts
type AudioPlaybackConfig = {
  defaultSfx?: string | undefined;
  musicLoopDelayMs: number;
  resolveMusicFade: (fadeKind: FadeKind | undefined, hadTrack: boolean) => MusicFade;
};
const DEFAULT_CHOICE_SFX: "sfx/click.wav";
const musicAssetLabel: (src: string) => string;
type MusicFade = {
  fadeIn: number;
  fadeOut: number;
};
type MusicPlaybackContext = {
  fadeKind?: FadeKind | undefined;
};
const resetMusicTracking: () => void;
const useAudio: <FadeKind extends string>(music: MusicCue | undefined, config: AudioPlaybackConfig<FadeKind>, playback?: MusicPlaybackContext<FadeKind>) => { playSfx: (sfx: import("game").SfxCue) => void; muted: boolean; toggleMute: () => void; paused: boolean; togglePause: () => void; audioBlocked: boolean; };

// boot.ts
const bootGame: (game: GameDefinition) => void;
type GameDefinition = {
  App: ComponentType;
  bundlePath?: string | undefined;
  i18nResources: I18nResources;
  id: string;
  player?: WebPlayerOptions | undefined;
};
type WebPlayerOptions = {
  assets?: { fallbackPortrait?: string; fallbackBackground?: string; } | undefined;
  components?: Partial<import("types").TextGameComponents> | undefined;
  mobile?: { requirePortrait?: boolean; maxShortEdgePx?: number; } | undefined;
  saves?: { slots?: number; } | undefined;
  settings?: { themes?: readonly PlayerTheme[]; defaultTheme?: PlayerTheme; analytics?: { available?: boolean; defaultEnabled?: boolean; }; defaultVolumes?: { master?: number; music?: number; sfx?: number; }; } | undefined;
  storage?: { prefix?: string; migrateLegacy?: boolean; } | undefined;
};

