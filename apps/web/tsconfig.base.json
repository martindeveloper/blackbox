{
  "compilerOptions": {
    "target": "ES2022",
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "module": "ESNext",
    "moduleResolution": "bundler",
    "jsx": "react-jsx",
    "strict": true,
    "noEmit": true,
    "skipLibCheck": true,
    "isolatedModules": true,
    "verbatimModuleSyntax": true,
    "noUncheckedIndexedAccess": true,
    "resolveJsonModule": true,
    "paths": {
      "@engine/*": ["./src/engine/*"],
      "@game/*": ["./src/shells/editor-preview/*"],
      "@content-source": ["./src/engine/lib/bundleSource.ts"],
      "@preview-mode": ["./src/engine/lib/previewMode.stub.ts"],
      "@preview-reporter": ["./src/preview/PreviewReporter.stub.tsx"],
      "@preview-protocol": ["../editor/shared/previewProtocol.ts"]
    }
  }
}
