{
  "extends": "./tsconfig.base.json",
  "compilerOptions": {
    "paths": {
      "react/jsx-runtime": ["./node_modules/@types/react/jsx-runtime.d.ts"],
      "react/compiler-runtime": ["./node_modules/@types/react/compiler-runtime.d.ts"],
      "react": ["./node_modules/@types/react/index.d.ts"],
      "react-dom/client": ["./node_modules/@types/react-dom/client.d.ts"],
      "react-dom": ["./node_modules/@types/react-dom/index.d.ts"],
      "react-i18next": ["./node_modules/react-i18next/index.d.mts"],
      "i18next": ["./node_modules/i18next/index.d.mts"],
      "@engine/*": ["./src/engine/*"],
      "@analytics": ["./src/engine/lib/vercelAnalytics.ts"],
      "@content-source": ["./src/engine/lib/bundleSource.ts"],
      "@preview-mode": ["./src/engine/lib/previewMode.stub.ts"],
      "@preview-reporter": ["./src/preview/PreviewReporter.stub.tsx"],
      "@platform": ["./src/engine/lib/platform.web.release.ts"],
      "@preview-protocol": ["../editor/players/web/protocol.ts"]
    }
  }
}
