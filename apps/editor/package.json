{
  "name": "blackbox-editor",
  "version": "0.1.0",
  "private": true,
  "description": "Desktop authoring tool for Blackbox game projects",
  "license": "MIT",
  "author": "Blackbox",
  "type": "module",
  "main": "electron/main.mjs",
  "scripts": {
    "build:js": "rolldown -c rolldown.config.ts",
    "build:css": "tailwindcss -i ./src/app.css -o ./dist/style.css",
    "build:icon": "node ./scripts/build-icon.mjs",
    "build": "npm run build:icon && npm run build:js && npm run build:css && node ./scripts/sync-dist.mjs",
    "watch:js": "rolldown -c rolldown.config.ts --watch",
    "watch:css": "tailwindcss -i ./src/app.css -o ./dist/style.css --watch",
    "dev": "npm run build && concurrently -k -n js,css,server -c blue,magenta,green \"npm run watch:js\" \"npm run watch:css\" \"node --watch server.js --dev\"",
    "start": "node server.js",
    "postinstall": "node ./scripts/ensure-electron.mjs",
    "electron:dev": "node ./scripts/ensure-electron.mjs && node ./scripts/ensure-tools.mjs && npm run build && electron .",
    "electron:build:tools": "node ./scripts/ensure-tools.mjs --force",
    "electron:pack": "npm run build:icon && node ./scripts/build-electron.mjs",
    "electron:pack:skip-tools": "npm run build:icon && node ./scripts/build-electron.mjs --skip-tools",
    "electron:dist": "npm run electron:pack && electron-builder --config electron-builder.yml",
    "electron:dist:dir": "npm run electron:pack && electron-builder --config electron-builder.yml --dir",
    "test": "node --test server/*.test.js",
    "lint": "oxlint .",
    "lint:fix": "oxlint --fix .",
    "fmt": "oxfmt .",
    "fmt:check": "oxfmt --check .",
    "check": "npm run lint && npm run fmt:check"
  },
  "dependencies": {
    "@dagrejs/dagre": "^3.0.0",
    "@fastify/multipart": "^10.0.0",
    "@tanstack/react-router": "^1.170.15",
    "@xyflow/react": "^12.11.0",
    "chokidar": "^5.0.0",
    "fastify": "^5.8.5",
    "i18next": "^26.3.1",
    "lucide-react": "^1.17.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-i18next": "^17.0.8",
    "zustand": "^5.0.14"
  },
  "devDependencies": {
    "@tailwindcss/cli": "^4.3.0",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "concurrently": "^10.0.3",
    "electron": "^42.4.0",
    "electron-builder": "^26.15.2",
    "livereload": "^0.10.3",
    "oxfmt": "^0.54.0",
    "oxlint": "^1.69.0",
    "rolldown": "^1.1.1",
    "tailwindcss": "^4.3.0",
    "typescript": "^6.0.3"
  },
  "productName": "Blackbox Editor"
}
