{
  "name": "blackbox-editor",
  "version": "0.2.1",
  "private": true,
  "description": "Desktop authoring tool for Blackbox game projects",
  "homepage": "https://github.com/martindeveloper/blackbox",
  "license": "MIT",
  "author": "Blackbox",
  "type": "module",
  "main": "electron/main.mjs",
  "scripts": {
    "build": "node ./scripts/sync-build-stages.mjs && npm run build:icon && npm run build:js && npm run build:css && node ./scripts/sync-dist.mjs && node ./players/registry.mjs syncBuildAssets",
    "build:css": "tailwindcss -i ./src/app.css -o ./dist/style.css",
    "build:icon": "node ./scripts/build-icon.mjs && node ./scripts/build-appx-assets.mjs",
    "build:js": "rolldown -c rolldown.config.ts",
    "check": "npm run lint && npm run lint:react-compiler && npm run fmt:check",
    "dev": "npm run build && concurrently -k -n js,css,server -c blue,magenta,green \"npm run watch:js\" \"npm run watch:css\" \"node --watch server.js --dev\"",
    "electron:dev": "node ./scripts/ensure-electron.mjs && node ./scripts/ensure-tools.mjs && npm run build && electron .",
    "electron:dist": "npm run electron:pack && electron-builder --config electron-builder.yml",
    "electron:dist:dir": "npm run electron:pack && electron-builder --config electron-builder.yml --dir",
    "electron:pack": "npm run build:icon && node ./scripts/build-electron.mjs",
    "electron:release": "node ./scripts/build-release.mjs",
    "fmt": "oxfmt .",
    "fmt:check": "oxfmt --check .",
    "lint": "oxlint .",
    "lint:fix": "oxlint --fix .",
    "lint:react-compiler": "eslint src/",
    "postinstall": "node ./scripts/ensure-electron.mjs",
    "start": "node server.js",
    "test": "node --test server/*.test.js server/pipeline/**/*.test.js electron/*.test.mjs ../../scripts/lib/preflight/preflight.test.mjs",
    "version:bump": "node ./scripts/bump-version.mjs",
    "watch:css": "tailwindcss -i ./src/app.css -o ./dist/style.css --watch",
    "watch:js": "rolldown -c rolldown.config.ts --watch"
  },
  "dependencies": {
    "@fastify/multipart": "^10.0.0",
    "chokidar": "^5.0.0",
    "fastify": "^5.8.5",
    "livereload": "^0.10.3"
  },
  "devDependencies": {
    "@babel/core": "^8.0.1",
    "@dagrejs/dagre": "^3.0.0",
    "@tailwindcss/cli": "^4.3.1",
    "@tanstack/react-router": "^1.170.16",
    "@types/babel__core": "^7.20.5",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@typescript-eslint/parser": "^8.61.1",
    "@xyflow/react": "^12.11.0",
    "babel-plugin-react-compiler": "^1.0.0",
    "concurrently": "^10.0.3",
    "electron": "^42.4.1",
    "electron-builder": "^26.15.3",
    "eslint": "^10.5.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "i18next": "^26.3.1",
    "lucide-react": "^1.21.0",
    "oxfmt": "^0.55.0",
    "oxlint": "^1.70.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-i18next": "^17.0.8",
    "rolldown": "^1.1.2",
    "sharp": "^0.35.1",
    "tailwindcss": "^4.3.1",
    "typescript": "^6.0.3",
    "zustand": "^5.0.14"
  },
  "productName": "Blackbox Editor"
}
