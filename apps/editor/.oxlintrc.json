{
  "$schema": "./node_modules/oxlint/configuration_schema.json",
  "plugins": ["typescript", "unicorn", "oxc"],
  "categories": {
    "correctness": "error"
  },
  "rules": {},
  "ignorePatterns": ["dist/**", "node_modules/**"],
  "env": {
    "builtin": true
  },
  "overrides": [
    {
      "files": ["**/*.{js,mjs}"],
      "env": {
        "builtin": true,
        "node": true,
        "es2024": true
      },
      "rules": {
        "no-undef": "error"
      }
    }
  ]
}
